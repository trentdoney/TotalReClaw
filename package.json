{
  "name": "totalreclaw",
  "version": "0.3.0",
  "description": "OpenClaw operational memory that recalls prior records and session context before agents repeat work.",
  "type": "module",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SynapseGrid-Labs/TotalReClaw.git"
  },
  "bugs": {
    "url": "https://github.com/SynapseGrid-Labs/TotalReClaw/issues"
  },
  "homepage": "https://github.com/SynapseGrid-Labs/TotalReClaw#readme",
  "license": "MIT",
  "author": "Trent Doney",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw-skill",
    "memory",
    "debugging",
    "session-memory",
    "agent"
  ],
  "files": [
    "index.ts",
    "src/**/*.ts",
    "skills/**",
    "examples/**",
    "docs/ARCHITECTURE.md",
    "docs/images/totalreclaw-header-vip.svg",
    "docs/images/totalreclaw-architecture-vip.svg",
    "docs/images/totalreclaw-workflow-vip.svg",
    "scripts/install-remote.sh",
    "scripts/verify-remote.sh",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "pack:check": "node ./scripts/check-pack.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run pack:check"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.24"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
